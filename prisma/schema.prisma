// CRM CEF 2026 — Prisma schema (PostgreSQL / Neon)
// String fields hold constrained values, validated at the app boundary with Zod.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("ADMIN") // ADMIN | DEPARTAMENTO | ASSOCIADO

  // Endurecimento — bloqueio de conta (lockout com backoff)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lockoutCount        Int       @default(0) // nº de lockouts consecutivos → backoff exponencial

  // 2FA TOTP (opcional). totpSecret só é válido quando totpEnabled = true.
  totpSecret        String?
  totpEnabled       Boolean @default(false)
  totpRecoveryCodes String  @default("[]") // JSON: bcrypt hashes de uso único

  // Auto-cadastro: false = aguardando aprovação do admin (login bloqueado).
  approved Boolean @default(true)

  image       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  auditLogs       AuditLog[]
  member          Member?
  departments     UserDepartment[]
  moduleOverrides UserModuleOverride[]
}

model Department {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserDepartment[]
  members     Member[]
  events      Event[]
  permissions DeptModulePermission[]
}

// Permissões granulares de um departamento por módulo do CRM.
model DeptModulePermission {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  moduleSlug   String     // "associados" | "financeiro" | "eventos" | "aniversariantes" | "carteirinha"
  canView      Boolean    @default(true)
  canEdit      Boolean    @default(false)
  canCreate    Boolean    @default(false)
  canDelete    Boolean    @default(false)
  canExport    Boolean    @default(false)
  updatedAt    DateTime   @updatedAt

  @@unique([departmentId, moduleSlug])
  @@index([departmentId])
}

// Override individual de permissão — sobrepõe o departamento.
// null = não sobrepõe (usa a permissão do departamento).
model UserModuleOverride {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleSlug   String
  canView      Boolean?
  canEdit      Boolean?
  canCreate    Boolean?
  canDelete    Boolean?
  canExport    Boolean?
  overriddenBy String?  // userId do admin que configurou
  overriddenAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, moduleSlug])
  @@index([userId])
}

// Vínculo M:N usuário↔departamento. Permissão é aditiva (nunca subtrativa).
model UserDepartment {
  id           String   @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, departmentId])
  @@index([departmentId])
}

model Plan {
  id            String    @id @default(cuid())
  name          String
  monthlyPrice  Float
  billingPeriod String    @default("MENSAL") // MENSAL | ANUAL
  description   String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  members       Member[]
  payments      Payment[]
}

model Member {
  id             String    @id @default(cuid())
  registration   Int       @unique // matrícula (atribuída pela aplicação)
  cardValidUntil DateTime?          // null = usa 31/12 do ano corrente

  // Seção 01 — Informações Pessoais
  fullName  String
  sex       String // M | F
  email     String
  phone     String
  instagram String?
  whatsapp  String?
  birthDate DateTime
  cpf       String   @unique
  photoUrl  String?

  // Seção 02 — Endereço
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String // UF

  // Seção 03 — Saúde e Emergência
  bloodType        String // A+, A-, B+, B-, AB+, AB-, O+, O-, NAO_SEI
  emergencyName    String
  emergencyPhone   String
  healthConditions String  @default("[]") // JSON string array
  healthDetails    String?

  // Seção 04 — Experiência em Atividades de Montanha
  mountainExperience String // NUNCA | MENOS_1 | MAIS_1 | MAIS_5 | MAIS_10 | PARADO
  otherGroup         Boolean @default(false)
  otherGroupName     String?

  // Seção 05 — Interesses (escala 1-5)
  interestHiking     Int     @default(0)
  interestClimbing   Int     @default(0)
  interestCourse     Int     @default(0)
  interestBike       Int     @default(0)
  interestEcological Int     @default(0)
  suggestions        String?

  status         String    @default("ACTIVE") // ACTIVE | INACTIVE
  inactiveReason String?   // motivo de desligamento (preenchido pelo admin ao desativar)
  inactiveAt     DateTime? // data de saída informada pelo admin (pode diferir de deletedAt)
  planId    String?
  plan      Plan?     @relation(fields: [planId], references: [id])

  // Conta de login do associado (nível ASSOCIADO). null = sem acesso ao sistema.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Departamento ao qual o associado está vinculado (escopo do nível DEPARTAMENTO)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Plano Família: dependente aponta para o titular
  titularId  String?  @unique
  titular    Member?  @relation("TitularDependente", fields: [titularId], references: [id])
  dependente Member?  @relation("TitularDependente")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  payments           Payment[]
  eventRegistrations EventRegistration[]
  birthdayLogs       BirthdayMessageLog[]

  @@index([status])
  @@index([deletedAt])
}

model Payment {
  id             String    @id @default(cuid())
  memberId       String
  member         Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId         String?
  plan           Plan?     @relation(fields: [planId], references: [id])
  amount         Float
  referenceMonth Int // 1-12
  referenceYear  Int
  status         String    @default("PENDENTE") // PAGO | PENDENTE | ATRASADO
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?   // Observação da baixa
  receiptPath    String?   // Caminho do comprovante (arquivo local)
  receiptNumber  String?   // Número do recibo gerado (YYYY-NNNN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([memberId, referenceMonth, referenceYear])
  @@index([status])
  @@index([referenceYear, referenceMonth])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // ENTRADA | SAIDA
  category    String
  description String
  amount      Float
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([date])
}

model Event {
  id          String   @id @default(cuid())
  name        String
  description String
  dateTime    DateTime
  location    String
  difficulty  String // FACIL | MODERADO | DIFICIL | TECNICO
  slots       Int      @default(0)
  status      String   @default("PLANEJADO") // PLANEJADO | CONFIRMADO | REALIZADO | CANCELADO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Departamento responsável pelo evento (escopo do nível DEPARTAMENTO)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  registrations EventRegistration[]
  photos        EventPhoto[]

  @@index([status])
  @@index([dateTime])
  @@index([departmentId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

model EventPhoto {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model BirthdayMessageConfig {
  id        String   @id @default(cuid())
  template  String   @default("Feliz aniversario, {nome}! O Clube Excursionista de Friburgo deseja um dia incrivel!")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id            String   @id @default(cuid())
  enrollmentFee Float    @default(50) // taxa de inscrição única para novos associados
  updatedAt     DateTime @updatedAt
}

model BirthdayMessageLog {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channel   String // WHATSAPP | EMAIL
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // CREATE | UPDATE | DELETE | LOGIN_SUCCESS | LOGIN_FAILED | LOCKOUT | LOGIN_OFFHOURS | EXPORT
  entity    String // Member | Plan | Payment | Event | Auth | ...
  entityId  String
  metadata  String? // JSON string
  ip        String? // endereço IP da requisição (LGPD)
  userAgent String? // user-agent da requisição (LGPD)
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
