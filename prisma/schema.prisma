// CRM CEF 2026 — Prisma schema (PostgreSQL / Neon)
// String fields hold constrained values, validated at the app boundary with Zod.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String
  role         String @default("ADMIN") // ADMIN | DEPARTAMENTO | ASSOCIADO

  // Endurecimento — bloqueio de conta (lockout com backoff)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lockoutCount        Int       @default(0) // nº de lockouts consecutivos → backoff exponencial

  // 2FA TOTP (opcional). totpSecret só é válido quando totpEnabled = true.
  totpSecret        String?
  totpEnabled       Boolean @default(false)
  totpRecoveryCodes String  @default("[]") // JSON: bcrypt hashes de uso único

  // Auto-cadastro: false = aguardando aprovação do admin (login bloqueado).
  approved Boolean @default(true)

  image           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  auditLogs       AuditLog[]
  member          Member?
  departments     UserDepartment[]
  moduleOverrides UserModuleOverride[]
}

model Department {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserDepartment[]
  members     Member[]
  events      Event[]
  permissions DeptModulePermission[]
}

// Permissões granulares de um departamento por módulo do CRM.
model DeptModulePermission {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  moduleSlug   String // "associados" | "financeiro" | "eventos" | "aniversariantes" | "carteirinha"
  canView      Boolean    @default(true)
  canEdit      Boolean    @default(false)
  canCreate    Boolean    @default(false)
  canDelete    Boolean    @default(false)
  canExport    Boolean    @default(false)
  updatedAt    DateTime   @updatedAt

  @@unique([departmentId, moduleSlug])
  @@index([departmentId])
}

// Override individual de permissão — sobrepõe o departamento.
// null = não sobrepõe (usa a permissão do departamento).
model UserModuleOverride {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleSlug   String
  canView      Boolean?
  canEdit      Boolean?
  canCreate    Boolean?
  canDelete    Boolean?
  canExport    Boolean?
  overriddenBy String? // userId do admin que configurou
  overriddenAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, moduleSlug])
  @@index([userId])
}

// Vínculo M:N usuário↔departamento. Permissão é aditiva (nunca subtrativa).
model UserDepartment {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, departmentId])
  @@index([departmentId])
}

model Plan {
  id            String    @id @default(cuid())
  name          String
  monthlyPrice  Float
  billingPeriod String    @default("MENSAL") // MENSAL | ANUAL
  description   String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  members       Member[]
  payments      Payment[]
}

model Member {
  id             String    @id @default(cuid())
  registration   Int       @unique // matrícula (atribuída pela aplicação)
  cardValidUntil DateTime? // null = usa 31/12 do ano corrente

  // Seção 01 — Informações Pessoais
  fullName  String
  sex       String // M | F
  email     String
  phone     String
  instagram String?
  whatsapp  String?
  birthDate DateTime
  cpf       String   @unique
  photoUrl  String?

  // Seção 02 — Endereço
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String // UF

  // Seção 03 — Saúde e Emergência
  bloodType        String // A+, A-, B+, B-, AB+, AB-, O+, O-, NAO_SEI
  emergencyName    String
  emergencyPhone   String
  healthConditions String  @default("[]") // JSON string array
  healthDetails    String?

  // Seção 04 — Experiência em Atividades de Montanha
  mountainExperience String // NUNCA | MENOS_1 | MAIS_1 | MAIS_5 | MAIS_10 | PARADO
  otherGroup         Boolean @default(false)
  otherGroupName     String?

  // Seção 05 — Interesses (escala 1-5)
  interestHiking     Int     @default(0)
  interestClimbing   Int     @default(0)
  interestCourse     Int     @default(0)
  interestBike       Int     @default(0)
  interestEcological Int     @default(0)
  interestEvent      Int     @default(0)
  suggestions        String?

  status         String    @default("ACTIVE") // ACTIVE | INACTIVE
  inactiveReason String? // motivo de desligamento (preenchido pelo admin ao desativar)
  inactiveAt     DateTime? // data de saída informada pelo admin (pode diferir de deletedAt)

  // Pode atuar como guia em atividades outdoor (Escalada, Caminhada, Bike, Acampamento).
  isGuide Boolean @default(false)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  // Conta de login do associado (nível ASSOCIADO). null = sem acesso ao sistema.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Departamento ao qual o associado está vinculado (escopo do nível DEPARTAMENTO)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Plano Família: dependente aponta para o titular
  titularId  String? @unique
  titular    Member? @relation("TitularDependente", fields: [titularId], references: [id])
  dependente Member? @relation("TitularDependente")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  payments             Payment[]
  eventRegistrations   EventRegistration[]
  attendedEvents       EventAttendee[]
  guidedEvents         Event[]               @relation("EventGuide")
  waitlistEntries      EventWaitlist[]
  caronasOferecidas    EventCarona[]         @relation("CaronaDriver")
  caronasPassageiro    EventCaronaPassenger[] @relation("CaronaPassenger")
  birthdayLogs         BirthdayMessageLog[]
  physicalCardRequests PhysicalCardRequest[]

  @@index([status])
  @@index([deletedAt])
  @@index([isGuide])
}

model Payment {
  id             String    @id @default(cuid())
  memberId       String
  member         Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId         String?
  plan           Plan?     @relation(fields: [planId], references: [id])
  amount         Float
  referenceMonth Int // 1-12
  referenceYear  Int
  status         String    @default("PENDENTE") // PAGO | PENDENTE | ATRASADO
  dueDate        DateTime
  paidAt         DateTime?
  notes          String? // Observação da baixa
  receiptPath    String? // Caminho do comprovante (arquivo local)
  receiptNumber  String? // Número do recibo gerado (YYYY-NNNN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([memberId, referenceMonth, referenceYear])
  @@index([status])
  @@index([referenceYear, referenceMonth])
}

model Transaction {
  id              String   @id @default(cuid())
  type            String // ENTRADA | SAIDA
  category        String
  subcategory     String?
  description     String
  amount          Float
  date            DateTime
  competenceMonth Int?
  competenceYear  Int?
  clubAccount     String?
  payerName       String?
  linkedActivity  String?
  paymentMethod   String?
  notes           String?
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  attachmentUrl   String?   // base64 data URL do comprovante
  attachmentName  String?   // nome original do arquivo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([date])
  @@index([supplierId])
}

model Event {
  id            String   @id @default(cuid())
  name          String
  description   String
  dateTime      DateTime
  location      String
  difficulty    String // FACIL | MODERADO | DIFICIL | TECNICO
  eventCategory String   @default("ATIVIDADE") // REUNIAO | ATIVIDADE
  slots         Int      @default(0)
  status        String   @default("PLANEJADO") // PLANEJADO | CONFIRMADO | REALIZADO | CANCELADO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Categoria detalhada (EVENT_CATEGORIES em lib/constants.ts).
  categoryCode String?

  // Campos específicos por tipo de evento
  speakerName          String? // Altos Papos: nome do palestrante
  filmDuration         String? // CEF Cine Montanha: duração (ex: "1h 45min")
  generalAttendeeNames String  @default("[]") // JSON: nomes do público em geral (não associados)
  guideIds             String  @default("[]") // JSON string[] — IDs de todos os guias (multi-guia)

  // Ficha Técnica — campos opcionais para caminhada (extensível a outras atividades outdoor)
  fichaDistanciaKm  Float?   // ex: 3.99
  fichaTempo        String?  // ex: "6h aprox."
  fichaEsforco      String?  // LEVE | MODERADO | INTENSO
  fichaInsolacao    String?  // BAIXO | MEDIO | ALTO
  fichaDesnivelPos  Int?     // metros, ex: 582
  fichaElevacaoMax  Int?     // metros, ex: 1713
  fichaExposicao    String?  // BAIXO | MODERADO | ALTO | EXTREMO
  fichaSaidaHorario String?  // ex: "8:00 h"
  fichaSaidaLocal   String?  // ex: "Super Pão"
  fichaCarona       Boolean  @default(false)
  fichaOQueLevar    String   @default("[]") // JSON string[]
  fichaObs          String?  // texto livre — OBS.:
  fichaAtencao      String?  // texto livre — ATENÇÃO:

  // Relatório pós-excursão preenchido pelo guia após a realização
  relatorioExcursao String?

  // Guia da atividade — Member com isGuide. Obrigatório quando categoria.requiresGuide.
  guideId String?
  guide   Member? @relation("EventGuide", fields: [guideId], references: [id])

  // Departamento responsável pelo evento (escopo do nível DEPARTAMENTO)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Fornecedor contratado para o evento (transporte, alimentação, etc.)
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  registrations EventRegistration[]
  attendees     EventAttendee[]
  photos        EventPhoto[]
  waitlist      EventWaitlist[]
  caronas       EventCarona[]

  @@index([status])
  @@index([dateTime])
  @@index([departmentId])
  @@index([categoryCode])
  @@index([guideId])
  @@index([supplierId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

model EventPhoto {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  memberId  String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

model EventWaitlist {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  position  Int      // order in queue (lower = first to be promoted)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
  @@index([eventId, position])
}

model EventCarona {
  id         String               @id @default(cuid())
  eventId    String
  event      Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  driverId   String
  driver     Member               @relation("CaronaDriver", fields: [driverId], references: [id], onDelete: Cascade)
  seats      Int                  @default(1)
  note       String?              // ponto de saída, observações
  createdAt  DateTime             @default(now())
  passengers EventCaronaPassenger[]

  @@unique([eventId, driverId])
  @@index([eventId])
}

model EventCaronaPassenger {
  id        String      @id @default(cuid())
  caronaId  String
  carona    EventCarona @relation(fields: [caronaId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member      @relation("CaronaPassenger", fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([caronaId, memberId])
  @@index([caronaId])
}

model BirthdayMessageConfig {
  id        String   @id @default(cuid())
  template  String   @default("Feliz aniversario, {nome}! O Clube Excursionista de Friburgo deseja um dia incrivel!")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id            String   @id @default(cuid())
  enrollmentFee Float    @default(50) // taxa de inscrição única para novos associados
  updatedAt     DateTime @updatedAt
}

model BirthdayMessageLog {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channel   String // WHATSAPP | EMAIL
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // CREATE | UPDATE | DELETE | LOGIN_SUCCESS | LOGIN_FAILED | LOCKOUT | LOGIN_OFFHOURS | EXPORT
  entity    String // Member | Plan | Payment | Event | Auth | ...
  entityId  String
  metadata  String? // JSON string
  ip        String? // endereço IP da requisição (LGPD)
  userAgent String? // user-agent da requisição (LGPD)
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model PhysicalCardRequest {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // PRIMEIRA_VIA | SEGUNDA_VIA
  requestType String @default("PRIMEIRA_VIA")

  // payment_pending | minimum_requirements | issuance_pending | in_production | awaiting_pickup | delivered | rejected
  currentStage        String
  eligibilitySnapshot String // JSON dos critérios no momento da criação

  approvedBy     String?
  approvedAt     DateTime?
  approvedNotes  String?
  rejectedReason String?

  // Segunda via — cobrança de R$ 30
  paymentAmount Float?
  paymentPaidAt DateTime?

  issuedAt      DateTime?
  readyAt       DateTime?
  deliveredAt   DateTime?
  receivedBy    String?
  deliveryNotes String?
  deliveredBy   String?

  quarter Int // 1 | 2 | 3 | 4
  year    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory PhysicalCardStatusHistory[]

  // Um sócio pode ter uma 1ª via e uma 2ª via por trimestre
  @@unique([memberId, quarter, year, requestType])
  @@index([currentStage])
  @@index([memberId])
  @@index([year, quarter])
}

model PhysicalCardStatusHistory {
  id        String              @id @default(cuid())
  requestId String
  request   PhysicalCardRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStage String?
  toStage   String
  changedBy String // nome/email do admin
  changedAt DateTime            @default(now())
  payload   String? // JSON com dados extras (reason, notes, etc.)

  @@index([requestId])
}

model Snapshot {
  id          String   @id @default(cuid())
  label       String
  data        String // JSON completo de todos os dados
  sizeBytes   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model TransactionCategory {
  id            String                   @id @default(cuid())
  type          String                   // ENTRADA | SAIDA
  name          String
  order         Int                      @default(0)
  subcategories TransactionSubcategory[]
  createdAt     DateTime                 @default(now())

  @@unique([type, name])
  @@index([type])
}

model TransactionSubcategory {
  id         String              @id @default(cuid())
  name       String
  categoryId String
  category   TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order      Int                 @default(0)
  createdAt  DateTime            @default(now())

  @@unique([categoryId, name])
  @@index([categoryId])
}

model SupplierCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

model Supplier {
  id           String        @id @default(cuid())
  name         String
  type         String        // nome da categoria (ex: "Transporte / Van")
  phone        String?
  email        String?
  document     String?       // CNPJ ou CPF
  pix          String?       // Chave PIX
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  events       Event[]

  @@index([type])
  @@index([active])
}
