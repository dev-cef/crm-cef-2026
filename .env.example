# =============================================================
# CRM CEF 2026 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Para Vercel: cole o conteúdo do .env em Settings → Environment Variables → Import .env
# =============================================================

# ─── Banco de Dados (Neon PostgreSQL) ─────────────────────────
# Obtenha em: console.neon.tech → seu projeto → Connection string
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require"

# ─── NextAuth.js ───────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="gere-com-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# ─── Evolution API (WhatsApp automático) ──────────────────────
# Instância já conectada ao WhatsApp do clube
EVOLUTION_API_URL="http://SEU_IP:PORTA"
EVOLUTION_API_KEY="sua-api-key-global"
EVOLUTION_INSTANCE="cef"
# JID do grupo do CEF (formato: 120363XXXXXXXXXX@g.us)
# Para obter: Evolution Manager → Instância → Groups → copie o ID do grupo
WHATSAPP_CEF_GROUP_JID=""

# ─── Resend (envio de e-mails transacionais) ───────────────────
# Usado para: reset de senha + envio automático de aniversários
# Obtenha em: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Cron (segurança do endpoint /api/cron/*) ──────────────────
# Gere com: openssl rand -hex 32
# Na Vercel: adicionar em Settings → Environment Variables
CRON_SECRET="gere-com-openssl-rand-hex-32"

# ─── Asaas (PIX automático — modo "Automático" em Cobrança) ────
# Obtenha em: asaas.com → conta sandbox ou produção → Integrações → API Key
ASAAS_API_KEY=""
ASAAS_ENV="sandbox"   # sandbox | production
# Gere com: openssl rand -hex 32
# Cadastre o webhook https://SEU_DOMINIO/api/webhooks/asaas na Asaas com o
# header "asaas-access-token" igual a este valor.
ASAAS_WEBHOOK_TOKEN=""

# ─── E-mail (SMTP) ─────────────────────────────────────────────
# Usado para envio manual de mensagens de aniversário pela UI
# Exemplos: Gmail, Brevo, Resend (via SMTP), Mailgun
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"          # true para porta 465 (SSL), false para 587 (TLS/STARTTLS)
SMTP_USER="seu@email.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="CEF <seu@email.com>"

# ─── Apple Wallet (.pkpass) ────────────────────────────────────
# Requer Apple Developer Program (US$ 99/ano)
# Guia: https://developer.apple.com/documentation/walletpasses
#
# 1. Crie um Pass Type ID em developer.apple.com → Certificates, IDs & Profiles
# 2. Gere e baixe o certificado (.p12)
# 3. Extraia cert e chave: openssl pkcs12 -in cert.p12 -clcerts -nokeys | base64
#    e: openssl pkcs12 -in cert.p12 -nocerts -nodes | base64
# 4. Baixe WWDR G4: https://www.apple.com/certificateauthority/
#    e converta: base64 -i AppleWWDRCAG4.cer
#
APPLE_PASS_TYPE_ID="pass.br.org.cef.carteirinha"
APPLE_TEAM_ID="SEU_TEAM_ID_10_CHARS"
APPLE_CERT_PEM=""            # Certificado .p12 exportado em base64
APPLE_KEY_PEM=""             # Chave privada extraída do .p12 em base64
APPLE_WWDR_PEM=""            # Apple WWDR G4 em base64

# ─── Google Wallet ─────────────────────────────────────────────
# Requer Google Cloud Project + Google Wallet API habilitada (gratuito)
# Guia: https://developers.google.com/wallet/generic/web/prerequisites
#
# 1. Acesse console.cloud.google.com → Crie projeto → Ative Google Wallet API
# 2. IAM → Service Accounts → crie conta → baixe chave JSON
# 3. Em pay.google.com/business/console → solicite acesso de emissor
# 4. Converta a chave privada: cat chave.json | base64
#
GOOGLE_WALLET_ISSUER_ID=""              # Número do emissor (ex: 3388000000123456789)
GOOGLE_WALLET_CLASS_SUFFIX="cef-carteirinha"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""        # email da service account
GOOGLE_SERVICE_ACCOUNT_KEY=""          # JSON da chave privada em base64

# ─── Vercel Blob (armazenamento de fotos) ──────────────────────────────────────
# Fotos de associados/eventos/patrimônio/capas vão pro Blob em vez de base64
# no banco. Sem esta variável, o sistema faz fallback e grava base64 (atual).
# Provisione em: Vercel > Storage > Blob (gera BLOB_READ_WRITE_TOKEN).
BLOB_READ_WRITE_TOKEN=""
